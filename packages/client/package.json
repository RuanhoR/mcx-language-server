{
  "name": "mcx-vscode-client",
  "version": "1.0.0",
  "displayName": "MCX Language Support for vscode(cli by mbler)",
  "description": "MCX VSCode Client",
  "publisher": "ruanhor",
  "license": "MIT",
  "author": "ruanhor",
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onLanguage:mcx"
  ],
  "repository": {
    "url": "https://github.com/RuanhoR/mcx-language-server"
  },
  "main": "dist/extension.js",
  "types": "dist/extension.d.ts",
  "scripts": {
    "build": "rollup -c",
    "vscode-build": "node scripts/vscode-build.js",
    "vscode:prepublish": "pnpm build",
    "test": "pnpm build && cd test && pnpm test"
  },
  "files": [
    "dist",
    "language-configuration.json",
    "syntaxes",
    "README.md",
    "tsconfig.json",
    "package.json",
    "LICENSE",
    "node_modules/@mbler/mcx-server/**",
    "node_modules/@mbler/mcx-ts-plugin/**",
    "node_modules/@mbler/mcx-core/**"
  ],
  "contributes": {
    "commands": [
      {
        "command": "mcx.restart.language",
        "title": "MCX: Restart Lanuage Server",
        "category": "MCX"
      }
    ],
    "languages": [
      {
        "id": "mcx",
        "aliases": [
          "MCX",
          "mcx"
        ],
        "extensions": [
          ".mcx"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "mcx",
        "scopeName": "text.mcx",
        "path": "./syntaxes/mcx.tmLanguage.json",
        "embeddedLanguages": {
          "meta.embedded.block.script.ts.mcx": "typescript",
          "meta.embedded.block.script.js.mcx": "javascript"
        }
      }
    ],
    "typescriptServerPlugins": [
      {
        "name": "@mbler/mcx-ts-plugin",
        "enableForWorkspaceTypeScriptVersions": true
      }
    ]
  },
  "dependencies": {
    "@mbler/mcx-core": "^0.0.5",
    "@mbler/mcx-server": "workspace:*",
    "@mbler/mcx-ts-plugin": "workspace:*",
    "@types/vscode": "^1.115.0",
    "@volar/vscode": "^2.4.28",
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "vsce": "^2.15.0"
  }
}
