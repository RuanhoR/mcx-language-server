{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "verbatimModuleSyntax": true,
    "module": "es2022",
    "target": "esnext",
    "moduleResolution": "bundler",
    "strict": true,
    "sourceMap": false,
    "declaration": false
  },
  "include": ["src/**/*.ts", "../dist/**/*"]
}
