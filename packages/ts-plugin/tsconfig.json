{
  "compilerOptions": {
    "target": "es2015",
    "module": "commonjs",
    "moduleResolution": "node",
    "rootDir": "src",
    "outDir": "dist",
    "declaration": true,
    "declarationMap": false,
    "sourceMap": false,
    "strict": true,
    "verbatimModuleSyntax": false,
    "skipLibCheck": true,
    "allowJs": true
  },
  "include": [
    "src/**/*.ts"
  ]
}